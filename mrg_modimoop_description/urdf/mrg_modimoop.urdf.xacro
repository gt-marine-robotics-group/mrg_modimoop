<?xml version="1.0" ?>
<!-- =================================================================================== -->
<!-- |    This document was autogenerated by xacro from /root/mrg_ws/install/share/mrg_modimoop/urdf/mrg_modimoop.urdf.xacro | -->
<!-- |    EDITING THIS FILE BY HAND IS NOT RECOMMENDED                                 | -->
<!-- =================================================================================== -->
<!-- Basic MODIMOOP description -->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" xmlns:gz="http://gazebosim.org/schema" name="MODIMOOP">

  <!-- ===================== -->
  <!-- Common parameters     -->
  <!-- ===================== -->
  <xacro:property name="mesh_scale" value="0.001 0.001 0.001"/>
  <xacro:property name="backwing_mesh_scale" value="0.0004 0.0004 0.0004"/>
  <!-- Rough masses (kg). Replace with measured values -->
  <xacro:property name="m_hull"     value="22.83"/>
  <xacro:property name="m_keel"     value="0.01"/>        <!-- total for keel (plate+bulb) if single link -->
  <xacro:property name="m_wingsail" value="4.44"/>
  <xacro:property name="m_rudder"   value="0.34"/>
  <xacro:property name="m_backwing" value="0.17"/>
  <xacro:property name="rudder_rod_radius" value="0.0045"/>
  <xacro:property name="wingsail_rod_radius" value="0.01"/>
  <xacro:property name="backwing_rod_radius" value="0.008"/>
  <xacro:property name="rod_mass" value="0.001"/> 

  <!-- Simple diagonal inertias (kg·m²). Replace with real inertias -->
  <xacro:property name="I_small" value="0.02"/>

  <!-- Materials -->
  <material name="Grey"><color rgba="0.6 0.6 0.6 1.0"/></material>
  <material name="Blue"><color rgba="0.2 0.4 0.8 1.0"/></material>
  <material name="Red"><color rgba="0.8 0.2 0.2 1.0"/></material>
  <material name="Black"><color rgba="0.05 0.05 0.05 1.0"/></material>
  <material name="Pink"><color rgba="1.0 0.2 0.6 1.0"/></material>

  <!-- ===================== -->
  <!-- Links                 -->
  <!-- ===================== -->

  <!-- Hull is the base -->
  <link name="hull">
    <inertial>
      <!--<origin xyz="0 0.75915 -1.33874" rpy="0 0 0"/>-->
      <origin xyz="0.175 -0.55 0.15" rpy="0 0 1.570796"/>
      <!--<origin xyz="0.175 -1.1 0.575" rpy="0 0 0"/>-->
      <!--<origin xyz="0.175 -0.34085 0.575" rpy="0 0 0"/>-->
      <mass value="${m_hull}"/>
      <inertia ixx="3.70506895" ixy="-0.00022839" ixz="-0.00008461" iyy="0.96696277" iyz="-0.64724529" izz="2.83543540"/>
    </inertial>
    <visual>
      <origin xyz="-0.41 -0.725 0" rpy="1.570796 0 1.570796"/>
      <geometry>
        <mesh filename="package://mrg_modimoop_description/models/mrg_modimoop_base/hull/hull.STL" scale="${mesh_scale}"/>
      </geometry>
      <material name="Pink"/>
    </visual>
    <collision name="hull_collision">
      <origin xyz="0.178 -0.55 0.45" rpy="0 0 3.14159"/>
      <geometry>
        <box size="1.125 0.35 0.25"/>
      </geometry>
    </collision>
  </link>

  <!-- Wingsail (revolute about vertical axis for trim) -->
  <link name="wingsail">
    <inertial>
      <!--<origin xyz="0.15 0.034 0.5" rpy="1.570796 0 1.570796"/> -->
      <origin xyz="-0.1 0 0.6" rpy="0 0 1.570796"/>
      <mass value="${m_wingsail}"/>
      <inertia ixx="0.78628153" ixy="-0.00004262" ixz="-0.00044123" iyy="0.32623116" iyz="-0.05493911" izz="0.46187925"/>
    </inertial>
    <visual>
      <origin xyz="0.05 0.040 0" rpy="0 0 3.14159"/>
      <!--<origin xyz="-0.025 -0.015 0" rpy="0 0 0"/> -->
      <geometry>
        <mesh filename="package://mrg_modimoop_description/models/mrg_modimoop_base/mainsail/mainsail.STL" scale="${mesh_scale}"/>
      </geometry>
      <material name="Pink"/>
    </visual>
    <collision name="wingsail_collision">
      <origin xyz="-0.1 0.0 0.675" rpy="0 0 0"/>
      <geometry>
        <!-- chord, thickness, height (meters) -->
        <box size="0.30 0.04 1.32"/>
      </geometry>
    </collision>
  </link>

  <link name="backwing">
    <inertial>
      <origin xyz="-0.035 0.0 0.25" rpy="1.570796 0 1.570796"/>
      <mass value="${m_backwing}"/>
      <inertia ixx="0.00415255" ixy="0.00000002" ixz="0" iyy="0.00011550" iyz="-0.00000140" izz="0.00405022"/>
    </inertial>
    <visual>
      <origin xyz="1.3 0.0 -0.5" rpy="1.570796 0 -1.570796"/>
      <geometry>
        <mesh filename="package://mrg_modimoop_description/models/mrg_modimoop_base/tailwing/tailwing.STL" scale="${mesh_scale}"/>
      </geometry>
      <material name="Pink"/>
    </visual>
    <collision name="backwing_collision">
      <origin xyz="-0.05 0.0 0.25" rpy="0 0 0"/>
      <geometry>
        <!-- chord, thickness, height (meters) -->
        <box size="0.11 0.02 0.55"/>
      </geometry>
    </collision>
  </link>

  <!-- Rudder (revolute about vertical axis) -->
  <link name="rudder">
    <inertial>
      <origin xyz="-0.074 0 -0.074" rpy="0 0 0"/>
      <mass value="${m_rudder}"/>
      <inertia ixx="0.00323999" ixy="0.00000021" ixz="0.00000004" iyy="0.00089298" iyz="0.00069153" izz="0.00234885"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="-1.570796 1.570796 0"/>
      <geometry>
        <mesh filename="package://mrg_modimoop_description/models/mrg_modimoop_base/rudder/rudder.STL" scale="${mesh_scale}"/>
      </geometry>
      <material name="Black"/>
    </visual>
    <collision name="rudder_collision">
      <origin xyz="-0.074 0 -0.074" rpy="0 1.570796 0"/>
      <geometry>
        <!-- length (fore-aft), thickness, height (meters) -->
        <box size="0.15 0.01 0.15"/>
      </geometry>
    </collision>
  </link>

  <!-- Keel as a single link with two mesh components (plate + bulb) -->
  <link name="keel">
    <inertial>
      <!-- Set the CoM where you expect the keel COM; adjust for your CAD --> <!-- 0.175 -0.55 0.1 -->
      <origin xyz="0.0 0.575 -0.55" rpy="0 0 0"/>
      <mass value="${m_keel}"/>
      <inertia ixx="${m_keel*0.016}" ixy="0.0" ixz="0.0" iyy="${m_keel*0.016}" iyz="0.0" izz="${m_keel*0.016}"/>
    </inertial>

    <!-- Keel visual -->
    <visual>
      <!-- Align to plate’s CAD frame relative to keel link frame -->
      <origin xyz="0.57 0.6025 0" rpy="1.570796 0 -1.570796"/>
      <geometry>
        <mesh filename="package://mrg_modimoop_description/models/mrg_modimoop_base/keel/keel.STL" scale="${mesh_scale}"/>
      </geometry>
      <material name="Grey"/>
    </visual>

    <!-- Plate collision -->
    <collision name="keel_plate_collision">
      <origin xyz="0.0 0.6025 -0.55" rpy="0 0 0"/>
      <geometry>
        <!-- chord, thickness, span (meters) — tune -->
        <box size="0.175 0.0125 0.70"/>
      </geometry>
    </collision>


    <!-- Bulb collision -->
    <collision name="keel_bulb_collision">
      <origin xyz="0.0 0.6025 -0.79" rpy="1.570796 0 1.570796"/>
      <geometry>
        <!-- length is along cylinder Z axis in its collision frame -->
        <cylinder length="0.325" radius="0.045"/>
      </geometry>
    </collision>
  </link>

  <!-- ===================== -->
  <!-- Joints                -->
  <!-- ===================== -->

  <!-- Keel fixed to hull -->
  <joint name="keel_mount" type="fixed">
    <parent link="hull"/>
    <child link="keel"/>
    <origin xyz="0.175 -1.15 0.7" rpy="0 0 0"/>
  </joint>

  <!-- Wingsail rotates around Z (trim). Limit range ±90° by default -->
  <joint name="wingsail_joint" type="continuous">
    <parent link="hull"/>
    <child link="wingsail"/>
    <origin xyz="0.3 -0.545 0.65" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <dynamics damping="0.2" friction="0.0"/>
  </joint>

  <link name="backwing_hinge"/>

  <joint name="backwing_hinge_joint" type="fixed">
    <parent link="wingsail"/>
    <child link="backwing_hinge"/>
    <origin xyz="-0.8 0.0 0.4" rpy="0 0 0"/>
  </joint>

  <joint name="backwing_joint" type="continuous">
    <parent link="backwing_hinge"/>
    <child link="backwing"/>

    <origin xyz="0 0 0" rpy="0 0 0"/>

    <!-- coaxial -->
    <axis xyz="0 0 1"/>

    <dynamics damping="0.05" friction="0.0"/>
  </joint>

  <!-- Rudder rotates around Z for yaw -->
  <joint name="rudder_joint" type="continuous">
    <parent link="hull"/>
    <child link="rudder"/>
    <origin xyz="-0.1 -0.545 0.3" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <dynamics damping="0.1" friction="0.0"/>
  </joint>


  <link name = "rudder_rod">
    <inertial>
      <origin xyz="0 0 0" rpy = "0 0 0"/>
      <mass value="${rod_mass}"/>
      <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/>
    </inertial>

    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${rudder_rod_radius}" length="0.20"/>
      </geometry>
      <material name="Black"/>
    </visual>
  </link>

  <joint name="rudder_rod_mount" type="fixed">
    <parent link="hull"/>
    <child link="rudder_rod"/>
    <origin xyz="-0.1 -0.545 0.3" rpy="0 0 0"/>
  </joint>

  <link name="wingsail_rod">
    <inertial>
      <origin xyz="0.105 -0.1025 0" rpy="0 0 0"/>
      <mass value="${rod_mass}"/>
      <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/>
    </inertial>

    <visual>
      <origin xyz="0.105 -0.1025 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${wingsail_rod_radius}" length="0.40"/>
      </geometry>
      <material name="Black"/>
    </visual>
  </link>

  <joint name="wingsail_rod_mount" type="fixed">
    <parent link="hull"/>
    <child link="wingsail_rod"/>
    <origin xyz="0.2 -0.65 0.65" rpy="0 0 1.570796"/>
  </joint>

  <link name="backwing_rod_top">
    <inertial>
      <origin xyz="0 0 0.73" rpy="0 0 0"/>
      <mass value="${rod_mass}"/>
      <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/>
    </inertial>

    <visual>
      <!-- Rotate cylinder so it runs along X -->
      <origin xyz="-0.5 -0.025 0.73" rpy="0 1.570796 0"/>
      <geometry>
        <cylinder radius="${backwing_rod_radius}" length="1.2"/>
      </geometry>
      <material name="Black"/>
    </visual>
  </link>

  <link name="backwing_rod_bottom">
    <inertial>
      <origin xyz="0 0 0.32" rpy="0 0 0"/>
      <mass value="${rod_mass}"/>
      <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/>
    </inertial>

    <visual>
      <origin xyz="-0.5 -0.025 0.32" rpy="0 1.570796 0"/>
      <geometry>
        <cylinder radius="${backwing_rod_radius}" length="1.2"/>
      </geometry>
      <material name="Black"/>
    </visual>
  </link>

  <joint name="backwing_rod_top_mount" type="fixed">
    <parent link="wingsail"/>
    <child link="backwing_rod_top"/>
    <origin xyz="0.25 0.02 0.2" rpy="0 0 0"/>
  </joint>

  <joint name="backwing_rod_bottom_mount" type="fixed">
    <parent link="wingsail"/>
    <child link="backwing_rod_bottom"/>
    <origin xyz="0.25 0.02 0.05" rpy="0 0 0"/>
  </joint>

  <!-- ===================== -->
  <!-- Sensor frame links    -->
  <!-- ===================== -->

  <link name="imu_link"/>
  <joint name="imu_mount" type="fixed">
    <parent link="hull"/>
    <child link="imu_link"/>
    <!-- put IMU near your hull CG -->
    <origin xyz="0.175 -0.55 0.45" rpy="0 0 0"/>
  </joint>

  <link name="gps_link"/>
  <joint name="gps_mount" type="fixed">
    <parent link="hull"/>
    <child link="gps_link"/>
    <!-- e.g., GPS on deck -->
    <origin xyz="0.25 -0.55 0.75" rpy="0 0 0"/>
  </joint>  

  <link name="anemometer_link"/>
  <joint name="anemometer_mount" type="fixed">
    <parent link="hull"/>
    <child link="anemometer_link"/>
    <origin xyz="0.25 -0.55 1.00" rpy="0 0 0"/>
  </joint>

  <link name="mag_link"/>
  <joint name="mag_mount" type="fixed">
    <parent link="hull"/>
    <child link="mag_link"/>
    <origin xyz="0.20 -0.55 0.50" rpy="0 0 0"/>
  </joint>

  <gazebo>
    <plugin name="gz::sim::systems::SailLiftDrag"
            filename="asv_sim2-sail-lift-drag-system">
          <a0>0.0</a0>
          <cla>6.2832</cla>
          <alpha_stall>0.1592</alpha_stall>
          <cla_stall>-0.7083</cla_stall>
          <cda>0.63662</cda>
          <area>0.17</area>
          <fluid_density>1.225</fluid_density>
          <forward>1 0 0</forward>
          <upward>0 1 0</upward>
          <cp>-0.1 0 0.6</cp>
          <link_name>wingsail</link_name>
          <radial_symmetry>1</radial_symmetry>
          <topic>lift_drag</topic>
    </plugin>
  
    <plugin name="gz::sim::systems::SailLiftDrag"
            filename="asv_sim2-sail-lift-drag-system">
          <a0>0.0</a0>
          <cla>6.2832</cla>
          <alpha_stall>0.1592</alpha_stall>
          <cla_stall>-0.7083</cla_stall>
          <cda>0.63662</cda>
          <area>0.05</area>
          <fluid_density>1.225</fluid_density>
          <forward>1 0 0</forward>
          <upward>0 1 0</upward>
          <cp>-0.035 0.0 0.25</cp>
          <link_name>backwing</link_name>
          <radial_symmetry>1</radial_symmetry>
          <topic>lift_drag</topic>
    </plugin>

    <plugin name="gz::sim::systems::FoilLiftDrag"
            filename="asv_sim2-foil-lift-drag-system">
          <a0>0.0</a0>
          <cla>6.2832</cla>
          <alpha_stall>0.1592</alpha_stall>
          <cla_stall>-0.7083</cla_stall>
          <cda>0.63662</cda>
          <area>0.17</area>
          <fluid_density>1000</fluid_density>
          <forward>1 0 0</forward>
          <upward>0 1 0</upward>
          <cp>0.0 0.575 -0.55</cp>
          <link_name>keel</link_name>
          <radial_symmetry>1</radial_symmetry>
          <topic>lift_drag</topic>
        </plugin>
        <plugin name="gz::sim::systems::FoilLiftDrag"
            filename="asv_sim2-foil-lift-drag-system">
          <a0>0.0</a0>
          <cla>6.2832</cla>
          <alpha_stall>0.1592</alpha_stall>
          <cla_stall>-0.7083</cla_stall>
          <cda>0.63662</cda>
          <area>0.12</area>
          <fluid_density>1000</fluid_density>
          <forward>1 0 0</forward>
          <upward>0 1 0</upward>
          <cp>-0.074 0 -0.074</cp>
          <link_name>rudder</link_name>
          <radial_symmetry>1</radial_symmetry>
          <topic>lift_drag</topic>
        </plugin>

        <plugin
          filename="gz-waves1-hydrodynamics-system"
          name="gz::sim::systems::Hydrodynamics">

          <enable>none_mrg_modimoop::hull::hull_collision_collision</enable>

          <hydrodynamics>
            <damping_on>1</damping_on>
            <viscous_drag_on>1</viscous_drag_on>
            <pressure_drag_on>1</pressure_drag_on>
          </hydrodynamics>
          <markers>
            <update_rate>10</update_rate>
            <water_patch>0</water_patch>
            <waterline>0</waterline>
            <underwater_surface>0</underwater_surface>
          </markers>
        </plugin>
  </gazebo>

    <!-- ===================== -->
  <!-- Gazebo sensors        -->
  <!-- ===================== -->

  <!-- IMU -->
  <gazebo reference="imu_link">
    <sensor name="imu_sensor" type="imu">
      <always_on>1</always_on>
      <update_rate>200</update_rate>
      <visualize>0</visualize>
      <topic>/modimoop/imu</topic>
      <gz_frame_id>imu_link</gz_frame_id>

      <imu>
        <angular_velocity>
          <x><noise type="gaussian"><mean>0</mean><stddev>0.0002</stddev></noise></x>
          <y><noise type="gaussian"><mean>0</mean><stddev>0.0002</stddev></noise></y>
          <z><noise type="gaussian"><mean>0</mean><stddev>0.0002</stddev></noise></z>
        </angular_velocity>
        <linear_acceleration>
          <x><noise type="gaussian"><mean>0</mean><stddev>0.01</stddev></noise></x>
          <y><noise type="gaussian"><mean>0</mean><stddev>0.01</stddev></noise></y>
          <z><noise type="gaussian"><mean>0</mean><stddev>0.01</stddev></noise></z>
        </linear_acceleration>
        <orientation>
          <x><noise type="gaussian"><mean>0</mean><stddev>0.01</stddev></noise></x>
          <y><noise type="gaussian"><mean>0</mean><stddev>0.01</stddev></noise></y>
          <z><noise type="gaussian"><mean>0</mean><stddev>0.01</stddev></noise></z>
          <w><noise type="gaussian"><mean>0</mean><stddev>0.01</stddev></noise></w>
        </orientation>
      </imu>
    </sensor>
  </gazebo>

  <gazebo reference="anemometer_link">
    <sensor name="anemometer" type="custom" gz:type="anemometer">
      <always_on>1</always_on>
      <update_rate>30</update_rate>
      <topic>anemometer</topic>
      <gz_frame_id>aneomometer_link</gz_frame_id>
      <gz:anemometer>
         <!-- <noise type="gaussian">
         <mean>0.2</mean>
          <stddev>0.1</stddev>
         </noise> -->
      </gz:anemometer>
    </sensor>
  </gazebo>

  <!-- GPS / NavSat -->
  <gazebo reference="gps_link">
    <sensor name="gps_sensor" type="navsat">
      <always_on>1</always_on>
      <update_rate>10</update_rate>
      <topic>/modimoop/navsat</topic>
      <gz_frame_id>gps_link</gz_frame_id>
      <visualize>0</visualize>
    </sensor>
  </gazebo>

  <!-- Magnetometer -->
  <gazebo reference="mag_link">
    <sensor name="mag_sensor" type="magnetometer">
      <always_on>1</always_on>
      <update_rate>50</update_rate>
      <visualize>0</visualize>
      <topic>/modimoop/mag</topic>
      <gz_frame_id>mag_link</gz_frame_id>
      <magnetometer/>
    </sensor>
  </gazebo>

  <gazebo>
    <plugin filename="gz-sim-joint-state-publisher-system"
            name="gz::sim::systems::JointStatePublisher">
      <joint_name>wingsail_joint</joint_name>
      <joint_name>rudder_joint</joint_name>
      <joint_name>backwing_joint</joint_name>
      <topic>/modimoop/joint_state</topic>
      <update_rate>50</update_rate>
    </plugin>
  </gazebo>


  <gazebo>
    <plugin filename="gz-sim-joint-position-controller-system"
            name="gz::sim::systems::JointPositionController">
      <joint_name>wingsail_joint</joint_name>
      <topic>/modimoop/cmd/wingsail_pos</topic>
      <!-- optional PID knobs depending on version; start without -->
    </plugin>

    <plugin filename="gz-sim-joint-position-controller-system"
            name="gz::sim::systems::JointPositionController">
      <joint_name>rudder_joint</joint_name>
      <topic>/modimoop/cmd/rudder_pos</topic>
    </plugin>

    <plugin filename="gz-sim-joint-position-controller-system"
            name="gz::sim::systems::JointPositionController">
      <joint_name>backwing_joint</joint_name>
      <topic>/modimoop/cmd/backwing_pos</topic>
    </plugin>
  </gazebo>

</robot>

